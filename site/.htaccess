Options -MultiViews
RewriteEngine On
RewriteBase /

# Canonical host: redirect the legacy host only when the request did not
# arrive through the Cloudflare Worker for the public domain.
RewriteCond %{HTTP_HOST} ^(www\.)?mycamino\.semproxlab\.it$ [NC]
RewriteCond %{HTTP:X-Canonical-Host} !^mycamino\.it$ [NC]
RewriteRule ^ https://mycamino.it%{REQUEST_URI} [R=301,L,NE]

# Never expose dotfiles or internal source/debug files
RewriteRule "(^|/)\.(?!well-known/)" - [R=404,L,NC]
RewriteRule ^(?:README\.md|server\.js|debug-headers\.php)$ - [R=404,L,NC]
RewriteRule ^api/logs(?:/|$) - [R=404,L,NC]
RewriteRule ^data/(?:admin_auth|comments|day_og_overrides|ui_flags)\.json$ - [R=404,L,NC]

# Serve real files/directories as-is
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Never rewrite SEO/public files
RewriteRule ^robots\.txt$ - [L,NC]
RewriteRule ^sitemap\.xml$ - [L,NC]
RewriteRule ^favicon\.ico$ - [L,NC]

# API routes (PHP router)
RewriteRule ^api/?$ api/index.php [L,NC,QSA]
RewriteRule ^api/(.*)$ api/index.php [L,NC,QSA]

# Localized day route -> dynamic PHP day page
RewriteRule ^(it|en|es|fr)/day/(\d{4}-\d{2}-\d{2})/?$ day.php?lang=$1&date=$2 [L,NC,QSA]
RewriteRule ^(it|en|es|fr)/prologue/?$ day.php?lang=$1&date=prologue [L,NC,QSA]

# Localized map route -> static map page
RewriteRule ^(it|en|es|fr)/map/?$ map.html [L,NC]
RewriteRule ^(it|en|es|fr)/people/?$ people.html [L,NC]
RewriteRule ^(it|en|es|fr)/contatti/?$ contatti.html [L,NC]
RewriteRule ^(it|en|es|fr)/crea-il-tuo-diario/?$ crea-il-tuo-diario.html [L,NC]
RewriteRule ^it/guida-gratuita/?$ /it/guida-gratuita-al-cammino-di-santiago-francese/ [R=301,L,NC]
RewriteRule ^it/guida-gratuita-al-cammino-di-santiago-francese/?$ guida-gratuita.html [L,NC]
RewriteRule ^en/free-guide/?$ guida-gratuita.html [L,NC]
RewriteRule ^es/guia-gratuita/?$ guida-gratuita.html [L,NC]
RewriteRule ^fr/guide-gratuite/?$ guida-gratuita.html [L,NC]

# Localized home
RewriteRule ^(it|en|es|fr)/?$ index.html [L,NC]

# Optional root fallback
RewriteRule ^$ index.html [L]

# Video delivery hardening (avoid HTTP/2 protocol issues on some hosts/CDNs)
<IfModule mod_mime.c>
  AddType video/mp4 .mp4
  AddType video/quicktime .mov
</IfModule>

<IfModule mod_deflate.c>
  SetEnvIfNoCase Request_URI "\\.(mp4|mov)$" no-gzip=1
</IfModule>

<IfModule mod_headers.c>
  <Files "conchiglia-nera.html">
    Header set X-Robots-Tag "noindex, nofollow, noarchive, nosnippet, noimageindex"
  </Files>

  <FilesMatch "\\.(mp4|mov)$">
    Header set Accept-Ranges "bytes"
    Header unset Content-Encoding
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>
